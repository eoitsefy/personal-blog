generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PostStatus {
  DRAFT
  PUBLISHED
}

enum AssetKind {
  IMAGE
  AUDIO
  DOCUMENT
  VIDEO
  OTHER
}

enum UserRole {
  USER
  ADMIN
}

enum UserStatus {
  ACTIVE
  DISABLED
}

enum UserTokenType {
  INVITE
  PASSWORD_RESET
}

enum CommentStatus {
  PENDING
  PUBLISHED
  HIDDEN
  SPAM
}

enum CommentReportStatus {
  OPEN
  RESOLVED
  DISMISSED
}

enum PlacePrivacy {
  EXACT
  APPROXIMATE
  CITY_ONLY
  HIDDEN
}

enum CoordinateSystem {
  WGS84
  GCJ02
  BD09
}

enum AiUsageStatus {
  SUCCESS
  NO_EVIDENCE
  RATE_LIMITED
  BUDGET_EXHAUSTED
  PROVIDER_ERROR
  TIMEOUT
}

model User {
  id              String          @id @default(cuid())
  email           String          @unique
  passwordHash    String
  role            UserRole        @default(USER)
  status          UserStatus      @default(ACTIVE)
  emailVerifiedAt DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  posts           Post[]
  assets          Asset[]
  sessions        UserSession[]
  tokens          UserToken[]     @relation("TokenUser")
  createdTokens   UserToken[]     @relation("TokenCreator")
  comments        Comment[]
  commentReports  CommentReport[]
}

model UserSession {
  id         String    @id @default(cuid())
  tokenHash  String    @unique
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt  DateTime
  revokedAt  DateTime?
  lastSeenAt DateTime  @default(now())
  createdAt  DateTime  @default(now())

  @@index([userId, revokedAt, expiresAt])
  @@index([expiresAt])
}

model UserToken {
  id          String        @id @default(cuid())
  tokenHash   String        @unique
  type        UserTokenType
  email       String
  userId      String?
  user        User?         @relation("TokenUser", fields: [userId], references: [id], onDelete: Cascade)
  createdById String
  createdBy   User          @relation("TokenCreator", fields: [createdById], references: [id], onDelete: Cascade)
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime      @default(now())

  @@index([email, type, usedAt, expiresAt])
  @@index([userId, type, usedAt, expiresAt])
  @@index([createdById, createdAt(sort: Desc)])
}

model Post {
  id             String         @id @default(cuid())
  slug           String         @unique
  title          String
  excerpt        String?
  contentMd      String
  status         PostStatus     @default(DRAFT)
  publishedAt    DateTime?
  deletedAt      DateTime?
  authorId       String
  author         User           @relation(fields: [authorId], references: [id], onDelete: Restrict)
  categoryId     String?
  category       Category?      @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  assets         PostAssetRef[]
  tags           PostTag[]
  comments       Comment[]
  places         PostPlace[]
  commentsLocked Boolean        @default(false)
  aiChunks        AiContentChunk[]

  @@index([status, publishedAt(sort: Desc)])
  @@index([authorId, createdAt(sort: Desc)])
  @@index([categoryId, status, publishedAt(sort: Desc)])
  @@index([deletedAt, updatedAt(sort: Desc)])
}

model AiContentChunk {
  id             String   @id @default(cuid())
  postId         String
  post           Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  contentVersion String
  heading        String?
  chunkIndex     Int
  content        String
  embedding      Json?
  embeddingModel String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([postId, chunkIndex])
  @@index([postId, contentVersion])
  @@index([embeddingModel])
}

model AiUsage {
  requestId      String        @id
  actorKeyHash   String
  provider       String
  model          String?
  promptVersion  String
  status         AiUsageStatus
  latencyMs      Int
  inputUnits     Int           @default(0)
  outputUnits    Int           @default(0)
  retrievalCount Int           @default(0)
  sourcePostIds  Json
  errorCategory  String?
  createdAt      DateTime      @default(now())

  @@index([createdAt(sort: Desc)])
  @@index([actorKeyHash, createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
}

model AiRateLimit {
  key             String    @id
  attempts        Int       @default(0)
  windowStartedAt DateTime
  blockedUntil    DateTime?
  updatedAt       DateTime  @updatedAt

  @@index([updatedAt])
}

model AiBudgetUsage {
  periodKey    String   @id
  requestCount Int      @default(0)
  inputUnits   Int      @default(0)
  outputUnits  Int      @default(0)
  updatedAt    DateTime @updatedAt
}

model Category {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  posts     Post[]

  @@index([name])
}

model Tag {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  posts     PostTag[]

  @@index([name])
}

model PostTag {
  postId    String
  tagId     String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
  @@index([tagId])
}

model LoginThrottle {
  key             String    @id
  attempts        Int       @default(0)
  windowStartedAt DateTime
  blockedUntil    DateTime?
  updatedAt       DateTime  @updatedAt

  @@index([updatedAt])
}

model Asset {
  id           String         @id @default(cuid())
  ossKey       String         @unique
  url          String
  originalName String?
  kind         AssetKind      @default(IMAGE)
  mime         String
  size         Int
  width        Int?
  height       Int?
  durationMs   Int?
  sha256       String
  ownerId      String
  owner        User           @relation(fields: [ownerId], references: [id], onDelete: Restrict)
  isPublic     Boolean        @default(true)
  refCount     Int            @default(0)
  deletedAt    DateTime?
  createdAt    DateTime       @default(now())
  refs         PostAssetRef[]
  placeCovers  Place[]        @relation("PlaceCover")

  @@index([ownerId, createdAt(sort: Desc)])
  @@index([sha256])
  @@index([deletedAt, createdAt(sort: Desc)])
  @@index([kind, deletedAt, createdAt(sort: Desc)])
}

model Place {
  id               String           @id @default(cuid())
  slug             String           @unique
  name             String
  summary          String?
  locationLabel    String
  latitude         Decimal          @db.Decimal(9, 6)
  longitude        Decimal          @db.Decimal(9, 6)
  publicLatitude   Decimal?         @db.Decimal(9, 6)
  publicLongitude  Decimal?         @db.Decimal(9, 6)
  privacy          PlacePrivacy     @default(HIDDEN)
  coordinateSystem CoordinateSystem @default(WGS84)
  coordinateSource String
  occurredAt       DateTime?
  coverAssetId     String?
  coverAsset       Asset?           @relation("PlaceCover", fields: [coverAssetId], references: [id], onDelete: SetNull)
  deletedAt        DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  posts            PostPlace[]

  @@index([deletedAt, updatedAt(sort: Desc)])
  @@index([privacy, deletedAt, occurredAt(sort: Desc)])
  @@index([coverAssetId])
}

model PostPlace {
  postId    String
  placeId   String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  place     Place    @relation(fields: [placeId], references: [id], onDelete: Restrict)

  @@id([postId, placeId])
  @@index([placeId])
}

model Comment {
  id        String          @id @default(cuid())
  content   String
  status    CommentStatus   @default(PENDING)
  postId    String
  post      Post            @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String
  author    User            @relation(fields: [authorId], references: [id], onDelete: Restrict)
  parentId  String?
  parent    Comment?        @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[]       @relation("CommentReplies")
  reports   CommentReport[]
  editedAt  DateTime?
  deletedAt DateTime?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([postId, status, deletedAt, createdAt])
  @@index([authorId, deletedAt, createdAt(sort: Desc)])
  @@index([parentId, status, deletedAt, createdAt])
}

model CommentReport {
  id         String              @id @default(cuid())
  commentId  String
  comment    Comment             @relation(fields: [commentId], references: [id], onDelete: Cascade)
  reporterId String
  reporter   User                @relation(fields: [reporterId], references: [id], onDelete: Restrict)
  reason     String
  status     CommentReportStatus @default(OPEN)
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  @@unique([commentId, reporterId])
  @@index([status, createdAt(sort: Desc)])
}

model CommentRateLimit {
  key             String    @id
  attempts        Int       @default(0)
  windowStartedAt DateTime
  blockedUntil    DateTime?
  updatedAt       DateTime  @updatedAt

  @@index([updatedAt])
}

model PostAssetRef {
  postId    String
  assetId   String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  asset     Asset    @relation(fields: [assetId], references: [id], onDelete: Restrict)

  @@id([postId, assetId])
  @@index([assetId])
}
