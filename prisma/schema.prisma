generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PostStatus {
  DRAFT
  PUBLISHED
}

enum AssetKind {
  IMAGE
  AUDIO
  DOCUMENT
  VIDEO
  OTHER
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         String   @default("ADMIN")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  posts        Post[]
  assets       Asset[]
}

model Post {
  id          String         @id @default(cuid())
  slug        String         @unique
  title       String
  excerpt     String?
  contentMd   String
  status      PostStatus     @default(DRAFT)
  publishedAt DateTime?
  deletedAt   DateTime?
  authorId    String
  author      User           @relation(fields: [authorId], references: [id], onDelete: Restrict)
  categoryId  String?
  category    Category?      @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  assets      PostAssetRef[]
  tags        PostTag[]

  @@index([status, publishedAt(sort: Desc)])
  @@index([authorId, createdAt(sort: Desc)])
  @@index([categoryId, status, publishedAt(sort: Desc)])
  @@index([deletedAt, updatedAt(sort: Desc)])
}

model Category {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  posts     Post[]

  @@index([name])
}

model Tag {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  posts     PostTag[]

  @@index([name])
}

model PostTag {
  postId    String
  tagId     String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
  @@index([tagId])
}

model LoginThrottle {
  key             String    @id
  attempts        Int       @default(0)
  windowStartedAt DateTime
  blockedUntil    DateTime?
  updatedAt       DateTime  @updatedAt

  @@index([updatedAt])
}

model Asset {
  id           String         @id @default(cuid())
  ossKey       String         @unique
  url          String
  originalName String?
  kind         AssetKind      @default(IMAGE)
  mime         String
  size         Int
  width        Int?
  height       Int?
  durationMs   Int?
  sha256       String
  ownerId      String
  owner        User           @relation(fields: [ownerId], references: [id], onDelete: Restrict)
  isPublic     Boolean        @default(true)
  refCount     Int            @default(0)
  deletedAt    DateTime?
  createdAt    DateTime       @default(now())
  refs         PostAssetRef[]

  @@index([ownerId, createdAt(sort: Desc)])
  @@index([sha256])
  @@index([deletedAt, createdAt(sort: Desc)])
  @@index([kind, deletedAt, createdAt(sort: Desc)])
}

model PostAssetRef {
  postId    String
  assetId   String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  asset     Asset    @relation(fields: [assetId], references: [id], onDelete: Restrict)

  @@id([postId, assetId])
  @@index([assetId])
}
