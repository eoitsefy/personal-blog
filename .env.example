POSTGRES_PASSWORD=replace-with-a-strong-database-password
DATABASE_URL=postgresql://blog:replace-with-a-strong-database-password@postgres:5432/blogdb?schema=public

# Used only by `npm run admin:create`.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-a-strong-admin-password

# Local media storage. Docker mounts /var/www/personal-blog/uploads at this path.
UPLOAD_ROOT=/app/uploads
MAX_UPLOAD_BYTES=8388608
# Includes active assets and recycle-bin assets until files are permanently deleted.
MAX_MEDIA_STORAGE_BYTES=2147483648

# Phase 5B public map. The Web JS API key is intentionally browser-visible.
# Keep the AMap securityJsCode out of this file and inject it only through the
# Nginx /_AMapService proxy described in docs/codex/06_DEPLOYMENT_RUNBOOK.md.
MAP_PROVIDER=none
AMAP_JS_API_KEY=

# Phase 6A text assistant. Keep disabled until the production connectivity,
# authentication, timeout, budget and failure-path checks have passed.
AI_ASSISTANT_ENABLED=false
AI_PROVIDER=openai
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=
AI_GENERATION_MODEL=gpt-5-nano
AI_EMBEDDING_MODEL=text-embedding-3-small
AI_REASONING_EFFORT=minimal
# Private random value used only to pseudonymize rate-limit buckets.
AI_ACTOR_SALT=
AI_TIMEOUT_MS=15000
AI_MAX_QUESTION_CHARS=500
AI_MAX_OUTPUT_TOKENS=300
AI_RETRIEVAL_LIMIT=4
AI_MIN_RELEVANCE=0.12
AI_RATE_LIMIT_WINDOW_SECONDS=600
AI_MAX_REQUESTS_PER_WINDOW=4
AI_RATE_LIMIT_BLOCK_SECONDS=1800
AI_MAX_DAILY_REQUESTS=50
AI_MAX_CONCURRENT_REQUESTS=2
AI_CIRCUIT_FAILURE_THRESHOLD=3
AI_CIRCUIT_COOLDOWN_SECONDS=60
